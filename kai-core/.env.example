# KAI CORE runtime
KAI_ENV=development
KAI_LOG_LEVEL=INFO
KAI_AUDIT_LOG=logs/audit.jsonl
KAI_MEMORY_PATH=logs/operational_memory.jsonl

# Google Apps Script Connector v3
KAI_DRIVE_CONNECTOR_URL=
KAI_DRIVE_CONNECTOR_TOKEN=
KAI_DRIVE_CONNECTOR_TIMEOUT=30

# GitHub research
GITHUB_TOKEN=

# Optional vector store backend
KAI_VECTOR_STORE=local
